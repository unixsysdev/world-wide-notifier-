# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# AI Service API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
NOTIFICATION_EMAIL=your_notification_email_here

# Teams Webhook (optional)
TEAMS_WEBHOOK=your_teams_webhook_url_here

# Hostname Configuration (use localhost for local development)
HOSTNAME=localhost

# JWT Secret for authentication (generate a secure random string)
JWT_SECRET=your_secure_jwt_secret_here

# Internal API key for service-to-service communication (generate a secure random string)
INTERNAL_API_KEY=your_internal_api_key_here