# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# AI Service API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
NOTIFICATION_EMAIL=notification@mon.duckerhub.com

# Teams Webhook (optional)
TEAMS_WEBHOOK=your_teams_webhook_url_here

# Production Deployment Configuration
HOSTNAME=mon.duckerhub.com
API_URL=https://mon.duckerhub.com/api

# JWT Secret for authentication (REPLACE with output from make generate-keys)
JWT_SECRET=your_generated_jwt_secret_from_make_generate_keys

# Internal API key for service-to-service communication (REPLACE with output from make generate-keys)
INTERNAL_API_KEY=your_generated_internal_api_key_from_make_generate_keys
